{
  "app-id": "io.github.spyaj.monitorcontrol",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "command": "monitor-control",
  "finish-args": [
    "--share=ipc",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--talk-name=org.freedesktop.Flatpak"
  ],
  "modules": [
    {
      "name": "monitor-control",
      "buildsystem": "simple",
      "sources": [
        {
          "type": "dir",
          "path": "."
        }
      ],
      "build-commands": [
        "pip3 install --no-index --no-build-isolation --prefix=/app .",
        "install -D desktop/io.github.spyaj.monitorcontrol.desktop /app/share/applications/io.github.spyaj.monitorcontrol.desktop",
        "install -D desktop/io.github.spyaj.monitorcontrol.metainfo.xml /app/share/metainfo/io.github.spyaj.monitorcontrol.metainfo.xml",
        "install -D assets/monitor-control.svg /app/share/icons/hicolor/scalable/apps/io.github.spyaj.monitorcontrol.svg"
      ]
    }
  ]
}
